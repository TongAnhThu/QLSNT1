@model IEnumerable<QLSNT.Models.TonGiao>

@{
    ViewData["Title"] = "Danh sách Tôn giáo";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<h1>Danh sách Tôn giáo</h1>

<div class="row mb-3">
    <div class="col-md-6">
        <form asp-action="Index" method="get" class="d-flex">
            <div class="position-relative">
                <input type="text" id="searchBox" name="search" value="@ViewBag.Search"
                       class="form-control me-2"
                       placeholder="Tìm theo tên tôn giáo..." />

                <div id="suggestions"
                     class="list-group position-absolute w-100"
                     style="z-index:1000;"></div>
            </div>
    <button class="btn btn-primary">Tìm</button>

        </form>
    </div>
    <div class="col-md-6 text-end">
        <a asp-action="Create" class="btn btn-success">+ Thêm tôn giáo</a>
    </div>
</div>

<table class="table table-bordered table-striped">
    <thead class="table-light">
        <tr>
            <th>Mã Tôn Giáo</th>
            <th>Tên Tôn Giáo</th>
            <th>Ghi chú</th>
            <th style="width:180px;">Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.MaTonGiao</td>
                <td>@item.TenTonGiao</td>
                <td>@item.GhiChu</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.MaTonGiao" class="btn btn-info btn-sm">Chi tiết</a>
                    <a asp-action="Edit" asp-route-id="@item.MaTonGiao" class="btn btn-warning btn-sm">Sửa</a>
                    <a asp-action="Delete" asp-route-id="@item.MaTonGiao" class="btn btn-danger btn-sm">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <p><em>Chưa có dữ liệu tôn giáo.</em></p>
}
<script>
    const input = document.getElementById("searchBox");
    const box = document.getElementById("suggestions");

    input.addEventListener("input", async function () {
        const keyword = this.value;

        if (keyword.length < 1) {
            box.innerHTML = "";
            return;
        }

        const res = await fetch(`/Admin/TonGiao/Autocomplete?term=${keyword}`);
        const data = await res.json();

        box.innerHTML = "";

        data.forEach(item => {
            const div = document.createElement("a");
            div.classList.add("list-group-item", "list-group-item-action");
            div.textContent = item;

            div.onclick = () => {
                input.value = item;
                box.innerHTML = "";
            };

            box.appendChild(div);
        });
    });
</script>
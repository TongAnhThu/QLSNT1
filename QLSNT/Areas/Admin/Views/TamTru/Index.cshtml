@using QLSNT.Models
@model IEnumerable<QLSNT.Models.TamTru>

@{
    ViewData["Title"] = "Quản lý Tạm trú";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";


int stt = 1;


}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2 class="fw-bold text-primary m-0">
            <i class="bi bi-house-door-fill me-2"></i>
            @ViewData["Title"]
        </h2>

        <a asp-action="Create"
           class="btn btn-success shadow-sm px-4">
            <i class="bi bi-plus-lg"></i>
            Thêm mới
        </a>

    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["SuccessMessage"]
            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert">
            </button>
        </div>
    }

    <div class="card shadow-sm mb-4 border-0">

        <div class="card-body p-4">

            <form asp-action="Index"
                  method="get"
                  class="row g-3 align-items-end">

                <div class="col-md-3">

                    <label class="form-label small fw-bold text-muted text-uppercase">
                        Tỉnh
                    </label>

                    <select id="maTinh"
                            name="maTinh"
                            class="form-select">

                        <option value="">-- Chọn tỉnh --</option>

                        @foreach (var tinh in ViewBag.TinhList)
                        {
                            <option value="@tinh.MaTinhMoi"
                                    selected="@(ViewBag.MaTinh != null && ViewBag.MaTinh == tinh.MaTinhMoi)">
                                @tinh.TenTinhMoi
                            </option>
                        }

                    </select>

                </div>

                <div class="col-md-3">

                    <label class="form-label small fw-bold text-muted text-uppercase">
                        Xã
                    </label>

                    <select id="maXaMoi"
                            name="maXaMoi"
                            class="form-select">

                        <option value="">-- Chọn xã --</option>

                        @if (ViewBag.XaMoiList != null)
                        {
                            @foreach (var xa in ViewBag.XaMoiList)
                            {
                                <option value="@xa.MaXaMoi"
                                        selected="@(ViewBag.MaXaMoi != null && ViewBag.MaXaMoi == xa.MaXaMoi)">
                                    @xa.TenXaMoi
                                </option>
                            }
                        }

                    </select>

                </div>

                <div class="col-md-2">

                    <label class="form-label small fw-bold text-muted text-uppercase">
                        Từ ngày
                    </label>

                    <input type="date"
                           name="fromDate"
                           value="@ViewBag.FromDate?.ToString("yyyy-MM-dd")"
                           class="form-control" />

                </div>

                <div class="col-md-2">

                    <label class="form-label small fw-bold text-muted text-uppercase">
                        Đến ngày
                    </label>

                    <input type="date"
                           name="toDate"
                           value="@ViewBag.ToDate?.ToString("yyyy-MM-dd")"
                           class="form-control" />

                </div>

                <div class="col-md-2">

                    <label class="form-label small fw-bold text-muted text-uppercase">
                        Tìm kiếm
                    </label>

                    <input type="text"
                           name="keyword"
                           value="@ViewBag.Keyword"
                           class="form-control"
                           placeholder="CCCD, Họ tên..." />

                </div>

                <div class="col-md-12 d-flex gap-2">

                    <button type="submit"
                            class="btn btn-primary">
                        <i class="bi bi-funnel"></i>
                        Lọc
                    </button>

                    <a asp-action="Index"
                       class="btn btn-secondary">
                        <i class="bi bi-arrow-clockwise"></i>
                        Làm mới
                    </a>

                </div>

            </form>

        </div>

    </div>

    <div class="card shadow-sm border-0">

        <div class="card-body p-0">

            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0">

                    <thead class="table-light">

                        <tr>
                            <th>STT</th>
                            <th>CCCD</th>
                            <th>Họ tên</th>
                            <th>Tỉnh</th>
                            <th>Xã</th>
                            <th>Địa chỉ</th>
                            <th>Ngày đăng ký</th>
                            <th class="text-center">Thao tác</th>
                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in Model)
                        {
                            <tr>

                                <td>@stt</td>

                                <td>@item.MaCCCD</td>

                                <td>
                                    @item.NguoiDan?.HoTen
                                </td>

                                <td>
                                    @item.XaMoi?.TinhMoi?.TenTinhMoi
                                </td>

                                <td>
                                    @item.XaMoi?.TenXaMoi
                                </td>

                                <td>
                                    @item.DiaChi,@item.XaMoi?.TenXaMoi, @item.XaMoi?.TinhMoi?.TenTinhMoi
                                </td>

                                <td>
                                    @(item.NgayDangKy?.ToString("dd/MM/yyyy"))
                                </td>

                                <td class="text-center">

                                    <div class="btn-group">

                                        <a asp-action="Details"
                                           asp-route-maXaMoi="@item.MaXaMoi"
                                           asp-route-maCCCD="@item.MaCCCD"
                                           class="btn btn-sm btn-info text-white">

                                            <i class="bi bi-eye"></i>

                                        </a>

                                        <a asp-action="Edit"
                                           asp-route-maXaMoi="@item.MaXaMoi"
                                           asp-route-maCCCD="@item.MaCCCD"
                                           class="btn btn-sm btn-warning text-white">

                                            <i class="bi bi-pencil-square"></i>

                                        </a>

                                        <a asp-action="Delete"
                                           asp-route-maXaMoi="@item.MaXaMoi"
                                           asp-route-maCCCD="@item.MaCCCD"
                                           class="btn btn-sm btn-danger">

                                            <i class="bi bi-trash"></i>

                                        </a>

                                    </div>

                                </td>

                            </tr>

                            stt++;
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>
    ```

</div>

@section Scripts
{
 <script>

          ```
              $("#maTinh").change(function () {

                  var maTinh = $(this).val();

                  $("#maXaMoi").empty();

                  $.get('/Admin/TamTru/GetXaByTinh',
                      { maTinh: maTinh },
                      function (data) {

                          $("#maXaMoi").append(
                              '<option value="">-- Chọn xã --</option>'
                          );

                          $.each(data, function (i, item) {

                              $("#maXaMoi").append(
                                  `<option value="${item.maXaMoi}">
                                      ${item.tenXaMoi}
                                   </option>`
                              );

                          });

                      });

              });

    </script>
    ```

}

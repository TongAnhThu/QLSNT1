@model QLSNT.Models.TamTru

@{
    ViewData["Title"] = "Thêm tạm trú";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="card shadow">

    
    <div class="card-header bg-success text-white">
        <h4 class="mb-0">
            Thêm thông tin tạm trú
        </h4>
    </div>

    <div class="card-body">

        <form asp-action="Create" method="post">

            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly"
                 class="text-danger mb-3">
            </div>

            <!-- CCCD -->

            <div class="mb-3">

                
                <label asp-for="MaCCCD" class="form-label fw-bold">
                    CCCD
                </label>

                <input asp-for="MaCCCD"
                       id="MaCCCD"
                       class="form-control"
                       maxlength="12"
                       placeholder="Nhập CCCD" />

                <span id="cccdError"
                      class="text-danger">
                </span>
                

            </div>

            <!-- Thông tin người dân -->

            <div id="thongTinNguoiDan"
                 class="card border-primary shadow-sm mb-3"
                 style="display:none;">

                
                <div class="card-header bg-primary text-white">

                    <i class="bi bi-person-vcard"></i>
                    Thông tin người dân

                </div>

                <div class="card-body">

                    <div class="row text-center">

                        <div class="col-md-4">

                            <div class="fw-bold text-secondary">
                                Họ tên
                            </div>

                            <div id="HoTen"
                                 class="fs-5">
                            </div>

                        </div>

                        <div class="col-md-4">

                            <div class="fw-bold text-secondary">
                                Ngày sinh
                            </div>

                            <div id="NgaySinh"
                                 class="fs-5">
                            </div>

                        </div>

                        <div class="col-md-4">

                            <div class="fw-bold text-secondary">
                                Giới tính
                            </div>

                            <div id="GioiTinh"
                                 class="fs-5">
                            </div>

                        </div>

                    </div>

                </div>
                

            </div>

            <div class="row mt-3">

                <div class="col-md-6">

                    <label asp-for="MaTinhMoi"
                           class="form-label fw-bold">
                        Tỉnh
                    </label>

                    <select asp-for="MaTinhMoi"
                            asp-items="ViewBag.TinhMoiList"
                            class="form-select"
                            id="tinhMoiSelect">

                        <option value="">
                            -- Chọn tỉnh --
                        </option>

                    </select>

                    <span asp-validation-for="MaTinhMoi"
                          class="text-danger">
                    </span>

                </div>

                <div class="col-md-6">

                    <label asp-for="MaXaMoi"
                           class="form-label fw-bold">
                        Xã
                    </label>

                    <select asp-for="MaXaMoi"
                            class="form-select"
                            id="xaMoiSelect">

                        <option value="">
                            -- Chọn xã --
                        </option>

                    </select>

                    <span asp-validation-for="MaXaMoi"
                          class="text-danger">
                    </span>

                </div>

            </div>

            <div class="mt-3">

                <label asp-for="DiaChi"
                       class="form-label fw-bold">
                    Địa chỉ chi tiết
                </label>

                <textarea asp-for="DiaChi"
                          class="form-control"
                          rows="2"></textarea>

                <span asp-validation-for="DiaChi"
                      class="text-danger">
                </span>

            </div>

            <div class="mt-3">

                <label asp-for="ThoiHan"
                       class="form-label fw-bold">
                    Thời hạn tạm trú
                </label>

                <input asp-for="ThoiHan"
                       class="form-control"
                       placeholder="Ví dụ: 6 tháng, 1 năm..." />

                <span asp-validation-for="ThoiHan"
                      class="text-danger">
                </span>

            </div>

            <div class="mt-3">

                <label asp-for="NoiDungDeNghi"
                       class="form-label fw-bold">
                    Nội dung đề nghị
                </label>

                <textarea asp-for="NoiDungDeNghi"
                          class="form-control"
                          rows="3"></textarea>

                <span asp-validation-for="NoiDungDeNghi"
                      class="text-danger">
                </span>

            </div>

            <hr />

            <button type="submit"
                    class="btn btn-success">
                <i class="bi bi-save"></i>
                Lưu
            </button>

            <a asp-action="Index"
               class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i>
                Quay lại
            </a>

        </form>

    </div>


</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />

    <script>

        const tinhMoiSelect =
            document.getElementById("tinhMoiSelect");

        const xaMoiSelect =
            document.getElementById("xaMoiSelect");

        tinhMoiSelect.addEventListener("change", function () {

            const maTinh = this.value;

            xaMoiSelect.innerHTML =
                "<option value=''>-- Chọn xã --</option>";

            if (!maTinh)
                return;

            fetch('/Admin/TamTru/GetXaByTinh?maTinh=' + maTinh)
                .then(response => response.json())
                .then(data => {

                    data.forEach(xa => {

                        const option =
                            document.createElement("option");

                        option.value = xa.maXaMoi;
                        option.text = xa.tenXaMoi;

                        xaMoiSelect.appendChild(option);

                    });

                });

        });

        $("#MaCCCD").on("input", function () {

            var cccd = $(this).val();

            if (cccd.length != 12) {
                $("#thongTinNguoiDan").hide();
                return;
            }

            $.get("/Admin/TamTru/GetNguoiDan",
                { cccd: cccd },
                function (data) {

                    if (data) {

                        $("#thongTinNguoiDan").show();

                        $("#HoTen").text(data.hoTen);
                        $("#NgaySinh").text(data.ngaySinh);
                        $("#GioiTinh").text(data.gioiTinh);
                    }
                    else {

                        $("#thongTinNguoiDan").hide();

                        $("#HoTen").text("");
                        $("#NgaySinh").text("");
                        $("#GioiTinh").text("");
                    }
                });
        });
    </script>


}

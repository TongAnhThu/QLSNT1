@{
    Layout = null;
}
@await RenderSectionAsync("Scripts", required: false)
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - QLSNT</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />

    <style>
        body {
            margin: 0;
        }

        /* NAVBAR */
        .navbar {
            height: 56px;
        }

        /* SIDEBAR */
        .sidebar {
            width: 250px;
            height: calc(100vh - 56px);
            background-color: #212529;
            color: white;
            position: fixed;
            top: 56px;
            left: 0;
            overflow-y: auto;
        }

            .sidebar h4 {
                text-align: center;
                padding: 15px;
                border-bottom: 1px solid #444;
            }

            .sidebar .nav-link {
                color: white;
                padding: 8px 15px;
                display: block;
                text-decoration: none;
            }

                .sidebar .nav-link:hover {
                    background-color: #0d6efd;
                    border-radius: 5px;
                }

        .section-title {
            font-weight: bold;
            margin: 10px 0 5px 10px;
            font-size: 14px;
            color: #ccc;
        }

        /* CONTENT */
        .content {
            margin-left: 250px;
            margin-top: 56px;
            padding: 20px;
        }
    </style>
</head>

<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom shadow-sm fixed-top">
        <div class="container-fluid">

            <!-- Logo -->
            <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                QLSNT
            </a>

            <!-- Toggle -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNavbar">

                <!-- LEFT -->
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                            Trang chủ
                        </a>
                    </li>
                </ul>

                <!-- RIGHT -->
                <ul class="navbar-nav ms-auto">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <span class="nav-link">
                                Xin chào, <strong>@User.Identity.Name</strong>
                            </span>
                        </li>

                        <li class="nav-item">
                            <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                                <button type="submit" class="btn btn-outline-danger ms-2">
                                    Đăng xuất
                                </button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">
                                Đăng nhập
                            </a>
                        </li>
                    }
                </ul>

            </div>
        </div>
    </nav>

    <!-- SIDEBAR -->
    <div class="sidebar">
        <h4>ADMIN</h4>

        <a class="nav-link" asp-area="Admin" asp-controller="Home" asp-action="Index">📊 Trang chủ</a>

        <div class="section-title">
            <a class="nav-link text-white" data-bs-toggle="collapse" href="#nguoiDanMenu" role="button">
                👨‍👩‍👧 Người dân
            </a>
        </div>

        <div class="collapse" id="nguoiDanMenu">

            <a class="nav-link ms-3" asp-area="Admin" asp-controller="NguoiDan" asp-action="Index">
                Người dân
            </a>

            <a class="nav-link ms-3" asp-area="Admin" asp-controller="DanToc" asp-action="Index">
                Dân tộc
            </a>

            <a class="nav-link ms-3" asp-area="Admin" asp-controller="TonGiao" asp-action="Index">
                Tôn giáo
            </a>

            <a class="nav-link ms-3" asp-area="Admin" asp-controller="TrinhDoVanHoa" asp-action="Index">
                Trình độ văn hóa
            </a>

            <a class="nav-link ms-3" asp-area="Admin" asp-controller="QuanHeChuHo" asp-action="Index">
                Quan hệ chủ hộ
            </a>

        </div>
        <!-- ĐVHC cũ -->
        <div class="section-title">
            <a class="nav-link text-white" data-bs-toggle="collapse" href="#dvhcCuMenu">
                🏛️ ĐVHC cũ
            </a>
        </div>
        <div class="collapse" id="dvhcCuMenu">
            <a class="nav-link ms-3" asp-area="Admin" asp-controller="TinhCu" asp-action="Index">Tỉnh</a>
            <a class="nav-link ms-3" asp-area="Admin" asp-controller="HuyenCu" asp-action="Index">Huyện</a>
            <a class="nav-link ms-3" asp-area="Admin" asp-controller="XaCu" asp-action="Index">Xã</a>
        </div>

        <!-- ĐVHC mới -->
        <div class="section-title">
            <a class="nav-link text-white" data-bs-toggle="collapse" href="#dvhcMoiMenu">
                🏢 ĐVHC mới
            </a>
        </div>
        <div class="collapse" id="dvhcMoiMenu">
            <a class="nav-link ms-3" asp-area="Admin" asp-controller="TinhMoi" asp-action="Index">Tỉnh</a>
            <a class="nav-link ms-3" asp-area="Admin" asp-controller="XaMoi" asp-action="Index">Xã</a>
        </div>

        <!-- Cư trú -->
        <div class="section-title">
            <a class="nav-link text-white" data-bs-toggle="collapse" href="#cuTruMenu">
                🏠 Cư trú
            </a>
        </div>
        <div class="collapse" id="cuTruMenu">
            <a class="nav-link ms-3" asp-area="Admin" asp-controller="ThuongTru" asp-action="Index">Thường trú</a>
            <a class="nav-link ms-3" asp-area="Admin" asp-controller="TamTru" asp-action="Index">Tạm trú</a>
            <a class="nav-link ms-3" asp-area="Admin" asp-controller="LichSuDiaChi" asp-action="Index">Lịch sử địa chỉ</a>
        </div>

        <!-- Sự kiện -->
        <div class="section-title">
            <a class="nav-link text-white" data-bs-toggle="collapse" href="#suKienMenu">
                📜 Sự kiện
            </a>
        </div>
        <div class="collapse" id="suKienMenu">
            <a class="nav-link ms-3" asp-area="Admin" asp-controller="SuKienHanhChinh" asp-action="Index">Sự kiện hành chính</a>
            <a class="nav-link ms-3" asp-area="Admin" asp-controller="LichSuSapNhap" asp-action="Index">Lịch sử sáp nhập</a>
        </div>
    </div>
    <!-- CONTENT -->
    <div class="content">
        @RenderBody()
    </div>

    <!-- SCRIPT -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
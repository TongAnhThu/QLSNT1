@model IEnumerable<QLSNT.Models.TinhCu>

@{
    ViewData["Title"] = "Danh sách Tỉnh cũ";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}
<link href="https://code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css" rel="stylesheet" />
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://code.jquery.com/ui/1.13.2/jquery-ui.min.js"></script>
<h1 class="mb-3">Danh sách Tỉnh cũ</h1>

<div class="row mb-3">
    <div class="col-md-6">
        <form asp-action="Index" method="get" class="d-flex">
            <<div class="position-relative w-100">
                <input type="text" id="searchBox"
                       name="search"
                       value="@ViewBag.Search"
                       class="form-control me-2"
                       placeholder="Nhập tên tỉnh cần tìm..." />

                <div id="suggestions"
                     class="list-group position-absolute w-100"
                     style="z-index:1000;"></div>
            </div>            
            <button class="btn btn-primary">Tìm</button>
        </form>
    </div>
    <div class="col-md-6 text-end">
        <a asp-action="Create" class="btn btn-success">
            + Thêm tỉnh cũ
        </a>
    </div>
</div>

@if (Model != null && Model.Any())
{
    <table class="table table-striped table-bordered align-middle">
        <thead class="table-light">
            <tr>
                <th>Mã tỉnh</th>
                <th>Tên tỉnh</th>
                <th>Loại tỉnh</th>
                <th>Trạng thái</th>
                <th>Ghi chú</th>
                <th style="width: 190px;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.MaTinhCu</td>
                    <td>@item.TenTinhCu</td>
                    <td>@item.LoaiTinh</td>
                    <td>@item.TrangThai</td>
                    <td>@item.GhiChu</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.MaTinhCu"
                           class="btn btn-sm btn-info">Chi tiết</a>
                        <a asp-action="Edit" asp-route-id="@item.MaTinhCu"
                           class="btn btn-sm btn-warning">Sửa</a>
                        <a asp-action="Delete" asp-route-id="@item.MaTinhCu"
                           class="btn btn-sm btn-danger">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p><em>Không tìm thấy bản ghi nào.</em></p>
}
<script>
    const input = document.getElementById("searchBox");
    const box = document.getElementById("suggestions");

    input.addEventListener("input", async function () {
        const keyword = this.value;

        if (keyword.length < 1) {
            box.innerHTML = "";
            return;
        }

        const res = await fetch(`/Admin/TinhCu/Autocomplete?term=${keyword}`);
        const data = await res.json();

        box.innerHTML = "";

        data.forEach(item => {
            const div = document.createElement("a");
            div.classList.add("list-group-item", "list-group-item-action");
            div.textContent = item;

            div.onclick = () => {
                input.value = item;
                box.innerHTML = "";
            };

            box.appendChild(div);
        });
    });
</script>
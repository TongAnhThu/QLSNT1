@model IEnumerable<QLSNT.Models.NguoiDan>

@{
    ViewData["Title"] = "Quản lý Người dân";
    var keyword = ViewBag.Keyword as string;
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0 fw-bold text-primary">Danh sách Người dân</h1>
    <a asp-controller="DangKyNguoiDan" asp-action="Create" class="btn btn-success">
        + Thêm người dân
    </a>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2">

            <!-- Ô tìm kiếm -->
            <div class="col-md-6 position-relative">
                <input type="text"
                       id="searchBox"
                       name="keyword"
                       value="@keyword"
                       class="form-control"
                       placeholder="Tìm theo CCCD, họ tên..." />

                <div id="suggestions"
                     class="list-group position-absolute w-100"
                     style="top: 100%; left: 0; z-index: 1000;"></div>
            </div>

            <!-- Nút tìm -->
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100">Tìm kiếm</button>
            </div>

            <!-- Nút xóa -->
            <div class="col-md-3 text-md-end">
                @if (!string.IsNullOrWhiteSpace(keyword))
                {
                    <a asp-action="Index" class="btn btn-outline-secondary w-100">Xóa lọc</a>
                }
            </div>

        </form>
    </div>
</div>

@if (Model != null && Model.Any())
{
    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>CCCD</th>
                            <th>Họ tên</th>
                            <th>Ngày sinh</th>
                            <th>Giới tính</th>
                            <th>Dân tộc</th>
                            <th>Tôn giáo</th>
                            <th style="width: 220px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.MaCCCD</td>
                                <td>@item.HoTen</td>
                                <td>@item.NgaySinh?.ToString("dd/MM/yyyy")</td>
                                <td>@item.GioiTinh</td>
                                <td>@item.DanToc?.TenDanToc</td>
                                <td>@item.TonGiao?.TenTonGiao</td>
                                <td>
                                    <a asp-controller="DangKyNguoiDan" asp-action="Details" asp-route-maCCCD="@item.MaCCCD"
                                       class="btn btn-sm btn-info me-1">Chi tiết</a>
                                    <a asp-controller="DangKyNguoiDan" asp-action="Edit" asp-route-maCCCD="@item.MaCCCD"
                                       class="btn btn-sm btn-warning me-1">Sửa</a>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <a asp-area="Admin"
                                           asp-controller="NguoiDan"
                                           asp-action="Delete"
                                           asp-route-id="@item.MaCCCD"
                                           class="btn btn-sm btn-danger"
                                           onclick="return confirm('Bạn có chắc muốn xóa người dân này?');">
                                            Xóa
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-info">
        Không tìm thấy người dân nào.
    </div>
}

<script>
    const input = document.getElementById("searchBox");
    const box = document.getElementById("suggestions");

    input.addEventListener("input", async function () {
        const keyword = this.value;
        console.log("Đang gõ:", keyword); // 👈 thêm dòng này

        if (keyword.length < 1) {
            box.innerHTML = "";
            return;
        }

        const res = await fetch(`/Admin/NguoiDan/Suggest?keyword=${keyword}`);
        const data = await res.json();

        console.log("Data trả về:", data); // 👈 thêm dòng này

        box.innerHTML = "";

        data.forEach(item => {
            const div = document.createElement("a");
            div.classList.add("list-group-item", "list-group-item-action");
            div.textContent = item;

            div.onclick = () => {
                input.value = item;
                box.innerHTML = "";
            };

            box.appendChild(div);
        });
    });
</script>
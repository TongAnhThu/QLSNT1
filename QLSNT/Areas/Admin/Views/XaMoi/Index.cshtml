@model IEnumerable<QLSNT.Models.XaMoi>

@{
    ViewData["Title"] = "Danh sách Xã mới";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<h1 class="mb-3">Danh sách Xã mới</h1>

<div class="row mb-3">
    <div class="col-md-6">
        <form asp-action="Index" method="get" class="d-flex">
            <div class="position-relative w-100">
                <input type="text"
                       id="searchBox"
                       name="search"
                       value="@ViewBag.Search"
                       class="form-control"
                       placeholder="Nhập tên xã / phường cần tìm..." />

                <div id="suggestions"
                     class="list-group position-absolute w-100 shadow"
                     style="top:100%; left:0; z-index:1000;"></div>
            </div>
            <button type="submit" class="btn btn-primary">Tìm kiếm</button>
        </form>
    </div>
    <div class="col-md-6 text-end">
        <a asp-action="Create" class="btn btn-success">
            + Thêm Xã mới
        </a>
    </div>
</div>

@if (Model != null && Model.Any())
{
    <table class="table table-striped table-bordered align-middle">
        <thead class="table-light">
            <tr>
                <th>Mã xã</th>
                <th>Tên xã</th>
                <th>Loại xã</th>
                <th>Trạng thái</th>
                <th>Ghi chú</th>
                <th style="width: 190px;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.MaXaMoi</td>
                    <td>@item.TenXaMoi</td>
                    <td>@item.LoaiXa</td>
                    <td>@item.TrangThai</td>
                    <td>@item.GhiChu</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.MaXaMoi"
                           class="btn btn-sm btn-info">Chi tiết</a>
                        <a asp-action="Edit" asp-route-id="@item.MaXaMoi"
                           class="btn btn-sm btn-warning">Sửa</a>
                        <a asp-action="Delete" asp-route-id="@item.MaXaMoi"
                           class="btn btn-sm btn-danger">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p><em>Không tìm thấy bản ghi nào.</em></p>
}
<script>
    const input = document.getElementById("searchBox");
    const box = document.getElementById("suggestions");

    input.addEventListener("input", async function () {
        const keyword = this.value;
        console.log("Đang gõ:", keyword); // 👈 thêm dòng này

        if (keyword.length < 1) {
            box.innerHTML = "";
            return;
        }

        const res = await fetch(`/Admin/XaMoi/Suggest?keyword=${keyword}`);
        const data = await res.json();

        console.log("Data trả về:", data); // 👈 thêm dòng này

        box.innerHTML = "";

        data.forEach(item => {
            const div = document.createElement("a");
            div.classList.add("list-group-item", "list-group-item-action");
            div.textContent = item;

            div.onclick = () => {
                input.value = item;
                box.innerHTML = "";
            };

            box.appendChild(div);
        });
    });
</script>

@model QLSNT.Models.ThuongTru

@{
    ViewData["Title"] = "Sửa Thường trú";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="card shadow">

    ```
    <div class="card-header bg-warning text-dark">
        <h4 class="mb-0">
            Sửa thông tin thường trú
        </h4>
    </div>

    <div class="card-body">

        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="MaCCCD" />
            <input type="hidden" asp-for="MaXaMoi" />
            <div class="mb-3">
                <label class="form-label fw-bold">CCCD</label>
                <input class="form-control"
                       value="@Model.MaCCCD"
                       readonly />

            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Địa chỉ hiện tại</label>
                <input class="form-control"
                       value="@($"{Model.DiaChi}, {Model.XaMoi?.TenXaMoi}, {Model.XaMoi?.TinhMoi?.TenTinhMoi}")"
                       readonly />
            </div>

            <div asp-validation-summary="ModelOnly"
                 class="text-danger mb-3">
            </div>

            <div class="row">

                <div class="col-md-6">

                    <label class="form-label fw-bold">
                        Họ tên
                    </label>

                    <input class="form-control"
                           value="@Model.NguoiDan?.HoTen"
                           readonly />

                </div>

                <div class="col-md-6">

                    <label class="form-label fw-bold">
                        CCCD
                    </label>

                    <input class="form-control"
                           value="@Model.MaCCCD"
                           readonly />

                </div>

            </div>

            <div class="row mt-3">

                <div class="col-md-6">

                    <label class="form-label fw-bold">
                        Tỉnh
                    </label>

                    <select id="MaTinh"
                            class="form-select"
                            asp-items="ViewBag.TinhList">
                        <option value="">
                            @Model.XaMoi?.TinhMoi?.TenTinhMoi
                        </option>
                    </select>

                </div>

                <div class="col-md-6">

                    <label class="form-label fw-bold">
                        Xã
                    </label>

                    <select asp-for="MaXaMoi"
                            id="MaXaMoi"
                            class="form-select"
                            asp-items="ViewBag.XaList">
                        <option value="">
                          @Model.XaMoi.TenXaMoi
                        </option>
                    </select>

                    <span asp-validation-for="MaXaMoi"
                          class="text-danger">
                    </span>

                </div>

            </div>
            <div class="mb-3">

                <label asp-for="DiaChi"
                       class="form-label fw-bold">
                    Địa chỉ chi tiết
                </label>

                <input asp-for="DiaChi"
                       class="form-control" />

                <span asp-validation-for="DiaChi"
                      class="text-danger">
                </span>

            </div>


            <div class="mt-3">

                <label class="form-label fw-bold">
                    Địa chỉ đầy đủ
                </label>

                <textarea class="form-control"
                          rows="2"
                          >@Model.DiaChi, @Model.XaMoi?.TenXaMoi, @Model.XaMoi?.TinhMoi?.TenTinhMoi</textarea>

            </div>

            <hr />

            
            <div class="mb-3">

                <label asp-for="NgayDangKy"
                       class="form-label fw-bold">
                    Ngày đăng ký
                </label>

                <input asp-for="NgayDangKy"
                       type="date"
                       class="form-control" />

                <span asp-validation-for="NgayDangKy"
                      class="text-danger">
                </span>

            </div>

            <button type="submit"
                    class="btn btn-primary">
                Cập nhật
            </button>

            <a asp-action="Index"
               class="btn btn-secondary">
                Quay lại
            </a>

        </form>

    </div>
    ```

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}

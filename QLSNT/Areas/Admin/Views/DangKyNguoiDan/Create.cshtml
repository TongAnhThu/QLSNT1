@model QLSNT.Models.NguoiDan

@{
    ViewData["Title"] = "Đăng ký người dân";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="fw-bold text-primary mb-4">Đăng ký người dân</h2>

<div class="card shadow-sm p-4">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <!-- Họ tên -->
        <div class="mb-3">
            <label asp-for="HoTen" class="form-label">Họ Tên</label>
            <input asp-for="HoTen" class="form-control" />
            <span asp-validation-for="HoTen" class="text-danger"></span>
        </div>

        <!-- Ngày sinh -->
        <div class="mb-3">
            <label asp-for="NgaySinh" class="form-label">Ngày Sinh</label>
            <input asp-for="NgaySinh" type="date" class="form-control" />
            <span asp-validation-for="NgaySinh" class="text-danger"></span>
        </div>

        <!-- Giới tính -->
        <div class="mb-3">
            <label asp-for="GioiTinh" class="form-label">Giới Tính</label>
            <select asp-for="GioiTinh" class="form-select">
                <option value="">-- Chọn giới tính --</option>
                <option value="Nam">Nam</option>
                <option value="Nữ">Nữ</option>
            </select>
            <span asp-validation-for="GioiTinh" class="text-danger"></span>
        </div>

        <!-- ===== ĐỊA CHỈ THƯỜNG TRÚ ===== -->
        <hr />
        <h5 class="fw-bold text-secondary mt-3">Địa chỉ thường trú</h5>

        <select id="tinhDropdown" name="MaTinhMoi" class="form-select" asp-items="ViewBag.TinhList">
            <option value="">-- Chọn tỉnh --</option>
        </select>

        <select id="xaDropdown" name="MaXaMoi" class="form-select">
            <option value="">-- Chọn xã --</option>
        </select>

        <div class="mb-3">
            <label class="form-label">Địa chỉ chi tiết</label>
            <input name="DiaChiThuongTru" class="form-control" />
        </div>

        <!-- Dân tộc -->
        <div class="mb-3">
            <label asp-for="MaDanToc" class="form-label">Dân Tộc</label>
            <select asp-for="MaDanToc" class="form-select" asp-items="ViewBag.DanTocList">
                <option value="">-- Chọn dân tộc --</option>
            </select>
        </div>

        <!-- Tôn giáo -->
        <div class="mb-3">
            <label asp-for="MaTonGiao" class="form-label">Tôn Giáo</label>
            <select asp-for="MaTonGiao" class="form-select" asp-items="ViewBag.TonGiaoList">
                <option value="">-- Chọn tôn giáo --</option>
            </select>
        </div>

        <!-- Trình độ văn hóa -->
        <div class="mb-3">
            <label asp-for="MaTDVH" class="form-label">Trình Độ Học Vấn</label>
            <select asp-for="MaTDVH" class="form-select" asp-items="ViewBag.TrinhDoList">
                <option value="">-- Chọn trình độ --</option>
            </select>
        </div>

        <!-- Tình trạng hôn nhân -->
        <div class="mb-3">
            <label asp-for="TinhTrangHonNhan" class="form-label">Tình Trạng Hôn Nhân</label>
            <select asp-for="TinhTrangHonNhan" class="form-select" asp-items="ViewBag.TinhTrangHonNhanList">
                <option value="">-- Chọn tình trạng --</option>
            </select>
        </div>

        <!-- Trạng thái công dân -->
        <div class="mb-3">
            <label asp-for="TrangThaiCongDan" class="form-label">Trạng Thái Công Dân</label>
            <select asp-for="TrangThaiCongDan" class="form-select" asp-items="ViewBag.TrangThaiCongDanList">
                <option value="">-- Chọn trạng thái --</option>
            </select>
        </div>

        <button type="submit" class="btn btn-primary">Tạo người dân</button>
        <a asp-action="Index" asp-controller="NguoiDan" class="btn btn-secondary">Quay lại</a>
    </form>
</div>

@section Scripts {
    <script>
        document.getElementById("tinhDropdown").addEventListener("change", function () {
            var maTinh = this.value;

            fetch('/Admin/DangKyNguoiDan/GetXaByTinh?maTinh=' + maTinh)
                .then(res => res.json())
                .then(data => {
                    var xaDropdown = document.getElementById("xaDropdown");
                    xaDropdown.innerHTML = '<option value="">-- Chọn xã --</option>';

                    data.forEach(x => {
                        var option = document.createElement("option");
                        option.value = x.id;
                        option.text = x.name;
                        xaDropdown.appendChild(option);
                    });
                });
        });
    </script>

    <partial name="_ValidationScriptsPartial" />
}
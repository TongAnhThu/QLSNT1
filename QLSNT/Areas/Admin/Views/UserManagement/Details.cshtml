@model Microsoft.AspNetCore.Identity.IdentityUser

@{
    ViewData["Title"] = "Chi tiết tài khoản";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";

    var roles = ViewBag.Roles as IList<string>;

    var allRoles =
        ViewBag.AllRoles as List<Microsoft.AspNetCore.Identity.IdentityRole>;

    var lichSu = ViewBag.LichSuHoatDong as List<NhatKyHoatDong>;
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-info text-white">

            <h4 class="mb-0">
                Chi tiết tài khoản
            </h4>

        </div>

        <div class="card-body">

            <div class="row mb-3">

                <div class="col-md-6">

                    <label>Email</label>

                    <input class="form-control"
                           value="@Model.Email"
                           readonly />

                </div>

                <div class="col-md-6">

                    <label>UserName</label>

                    <input class="form-control"
                           value="@Model.UserName"
                           readonly />

                </div>

            </div>

            <div class="mb-4">

                <label>Role hiện tại</label>

                <div>

                    @foreach (var role in roles)
                    {
                        <span class="badge bg-primary me-1">
                            @role
                        </span>
                    }

                </div>

            </div>

            <hr />

            <h5>Gán quyền</h5>

            <form asp-action="AssignRole"
                  method="post">

                @Html.AntiForgeryToken()

                <input type="hidden"
                       name="userId"
                       value="@Model.Id" />

                <div class="row">

                    <div class="col-md-8">

                        <select class="form-select"
                                name="roleName">

                            @foreach (var role in allRoles)
                            {
                                <option value="@role.Name">
                                    @role.Name
                                </option>
                            }

                        </select>

                    </div>

                    <div class="col-md-4">

                        <button class="btn btn-success w-100">
                            Cập nhật Role
                        </button>

                    </div>

                </div>

            </form>

            <hr />
            <hr />

            <h5 class="mb-3">
                <i class="fas fa-history text-primary"></i>
                Lịch sử hoạt động
            </h5>

            @if (lichSu != null && lichSu.Any())
            {
                <div class="table-responsive">

                    <table class="table table-bordered table-hover">

                        <thead class="table-light">
                            <tr>
                                <th width="180">Thời gian</th>
                                <th width="200">Hành động</th>
                                <th>Mô tả</th>
                                <th width="150">IP</th>
                            </tr>
                        </thead>

                        <tbody>

                            @foreach (var item in lichSu)
                            {
                                <tr>

                                    <td>
                                        @item.ThoiGian.ToString("dd/MM/yyyy HH:mm:ss")
                                    </td>

                                    <td>
                                        <span class="badge bg-info">
                                            @item.HanhDong
                                        </span>
                                    </td>

                                    <td>
                                        @item.MoTa
                                    </td>

                                    <td>
                                        @(string.IsNullOrEmpty(item.DiaChiIP)
                                            ? "-"
                                            : item.DiaChiIP)
                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>
            }
            else
            {
                <div class="alert alert-secondary">
                    Chưa có lịch sử hoạt động.
                </div>
            }
            <a asp-action="Index"
               class="btn btn-secondary">
                Quay lại
            </a>

        </div>

    </div>

</div>
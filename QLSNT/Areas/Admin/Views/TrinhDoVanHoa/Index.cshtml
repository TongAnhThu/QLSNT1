@model IEnumerable<QLSNT.Models.TrinhDoVanHoa>

@{
    ViewData["Title"] = "Danh sách Trình độ văn hóa";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<h1>Danh sách Trình độ văn hóa</h1>

<div class="row mb-3">
    <div class="col-md-6">
        <form asp-action="Index" method="get" class="d-flex">
            <div class="position-relative">
                <input type="text" id="searchBox" name="search" value="@ViewBag.Search"
                       class="form-control me-2"
                       placeholder="Tìm theo tên trình độ (ví dụ: 12/12, Đại học)..." />

                <div id="suggestions"
                     class="list-group position-absolute w-100"
                     style="z-index:1000;"></div>
            </div>
                  
            <button type="submit" class="btn btn-primary">Tìm kiếm</button>
        </form>
    </div>
    <div class="col-md-6 text-end">
        <a asp-action="Create" class="btn btn-success">+ Thêm trình độ mới</a>
    </div>
</div>

<table class="table table-striped table-bordered">
    <thead class="table-light">
        <tr>
            <th>Mã TDVH</th>
            <th>Tên trình độ</th>
            <th>Mô tả</th>
            <th style="width:180px;">Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.MaTDVH</td>
                <td>@item.TenTDVH</td>
                <td>@item.MoTa</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.MaTDVH" class="btn btn-sm btn-info">Chi tiết</a>
                    <a asp-action="Edit" asp-route-id="@item.MaTDVH" class="btn btn-sm btn-warning">Sửa</a>
                    <a asp-action="Delete" asp-route-id="@item.MaTDVH" class="btn btn-sm btn-danger">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <p><em>Chưa có dữ liệu trình độ văn hóa.</em></p>
}
<script>
    const input = document.getElementById("searchBox");
    const box = document.getElementById("suggestions");

    input.addEventListener("input", async function () {
        const keyword = this.value;

        if (keyword.length < 1) {
            box.innerHTML = "";
            return;
        }

        const res = await fetch(`/Admin/TrinhDoVanHoa/Autocomplete?term=${keyword}`);
        const data = await res.json();

        box.innerHTML = "";

        data.forEach(item => {
            const div = document.createElement("a");
            div.classList.add("list-group-item", "list-group-item-action");
            div.textContent = item;

            div.onclick = () => {
                input.value = item;
                box.innerHTML = "";
            };

            box.appendChild(div);
        });
    });
</script>
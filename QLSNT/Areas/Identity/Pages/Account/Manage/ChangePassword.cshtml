@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">

        
            <div class="card shadow border-0 rounded-4">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h4 class="mb-0">
                        <i class="fas fa-key me-2"></i>
                        Đổi mật khẩu
                    </h4>
                </div>

                <div class="card-body p-4">

                    <form id="change-password-form" method="post">
                        <div asp-validation-summary="ModelOnly"
                             class="alert alert-danger"
                             role="alert">
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.OldPassword"
                                   class="form-label fw-bold">
                                Mật khẩu hiện tại
                            </label>

                            <input asp-for="Input.OldPassword"
                                   type="password"
                                   class="form-control"
                                   placeholder="Nhập mật khẩu hiện tại" />

                            <span asp-validation-for="Input.OldPassword"
                                  class="text-danger">
                            </span>
                        </div>
                        

                        <div class="mb-3">
                            <label asp-for="Input.NewPassword"
                                   class="form-label fw-bold">
                                Mật khẩu mới
                            </label>

                            <input asp-for="Input.NewPassword"
                                   id="newPassword"
                                   type="password"
                                   class="form-control"
                                   placeholder="Nhập mật khẩu mới" />

                            <span asp-validation-for="Input.NewPassword"
                                  class="text-danger">
                            </span>

                            <div class="alert alert-light border mt-3">
                                <strong>Yêu cầu mật khẩu:</strong>

                                <ul class="mb-0 mt-2 list-unstyled">
                                    <li id="lengthRule" class="text-danger">
                                        ✖ Tối thiểu 8 ký tự
                                    </li>

                                    <li id="upperRule" class="text-danger">
                                        ✖ Có ít nhất 1 chữ in hoa
                                    </li>

                                    <li id="lowerRule" class="text-danger">
                                        ✖ Có ít nhất 1 chữ thường
                                    </li>

                                    <li id="numberRule" class="text-danger">
                                        ✖ Có ít nhất 1 chữ số
                                    </li>

                                    <li id="specialRule" class="text-danger">
                                        ✖ Có ít nhất 1 ký tự đặc biệt
                                    </li>
                                </ul>
                            </div>

                        </div>

                        <div class="mb-4">
                            <label asp-for="Input.ConfirmPassword"
                                   class="form-label fw-bold">
                                Xác nhận mật khẩu mới
                            </label>

                            <input asp-for="Input.ConfirmPassword"
                                   type="password"
                                   class="form-control"
                                   placeholder="Nhập lại mật khẩu mới" />

                            <span asp-validation-for="Input.ConfirmPassword"
                                  class="text-danger">
                            </span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit"
                                    class="btn btn-primary btn-lg">
                                <i class="fas fa-save me-2"></i>
                                Cập nhật mật khẩu
                            </button>

                            <a asp-page="./Index"
                               class="btn btn-secondary">
                                <i class="fas fa-arrow-left me-2"></i>
                                Quay lại
                            </a>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>


</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function () {

            $("#newPassword").on("keyup", function () {

                let password = $(this).val();

                updateRule("lengthRule", password.length >= 8);

                updateRule("upperRule",
                    /[A-Z]/.test(password));

                updateRule("lowerRule",
                    /[a-z]/.test(password));

                updateRule("numberRule",
                    /\d/.test(password));

                updateRule("specialRule",
                    /[^A-Za-z0-9]/.test(password));
            });

            function updateRule(id, valid) {

                let item = $("#" + id);

                if (valid) {

                    item.removeClass("text-danger")
                        .addClass("text-success");

                    item.html(item.text().replace("✖", "✔"));

                } else {

                    item.removeClass("text-success")
                        .addClass("text-danger");

                    item.html(item.text().replace("✔", "✖"));
                }
            }
        });
    </script>
}

@page
@model LoginModel

@{
    ViewData["Title"] = "Đăng nhập";
}

<link rel="stylesheet" href="~/css/Dangnhap.css" />

<div class="login-wrapper">
    <div class="login-box">

        <h4 class="title">Đăng nhập hệ thống</h4>
        <p class="subtitle">Nhập CCCD để tiếp tục</p>

        <form method="post">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <!-- CCCD -->
            <div class="input-box">
                <input asp-for="Input.MaCCCD" placeholder="Mã CCCD" />
                <span asp-validation-for="Input.MaCCCD" class="text-danger"></span>
            </div>

            <!-- Password -->
            <div class="input-box password-box">
                <input asp-for="Input.Password" type="password" placeholder="Mật khẩu" />
                <span class="toggle-password">👁</span>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <!-- Remember -->
            <div class="remember">
                <input asp-for="Input.RememberMe" />
                <label> Ghi nhớ đăng nhập</label>
            </div>

            <!-- Button -->
            <button type="submit" class="btn-login">Đăng nhập</button>

            <!-- Links -->
            <div class="links">
                <a asp-page="./ForgotPassword">Quên mật khẩu</a>
                <a asp-page="./Register">Đăng ký</a>
            </div>

        </form>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const toggle = document.querySelector(".toggle-password");
        if (toggle) {
            toggle.onclick = function () {
                const input = document.querySelector(".password-box input");
                input.type = input.type === "password" ? "text" : "password";
            };
        }
    </script>
}
@using QLSNT.Areas.User.ViewModel
@model DiaChiMoiViewModel

@{
    ViewData["Title"] = "Tra cứu địa chỉ";
}

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-9">

            <div class="card shadow">

                <div class="card-header bg-primary text-white">

                    <h3 class="mb-0">
                        Tra cứu địa chỉ hành chính mới
                    </h3>

                </div>

                <div class="card-body">

                    <!-- FORM -->

                    <form asp-action="TimKiem"
                          method="post">

                        <div class="mb-3">

                            <label class="form-label">

                                Nhập địa chỉ cũ

                            </label>

                            <input type="text"
                                   name="diaChiCu"
                                   class="form-control"
                                   placeholder="Ví dụ: Xã Tân Phú..." />

                        </div>

                        <button type="submit"
                                class="btn btn-primary">

                            Tra cứu

                        </button>

                    </form>

                    <!-- THÔNG BÁO -->
                    @if (ViewBag.Message != null)
                    {
                        <div class="alert alert-danger mt-3">

                            @ViewBag.Message

                        </div>
                    }

                    <!-- KẾT QUẢ -->
                    @if (Model != null && Model.DsXaMoi.Any())
                    {
                        <hr />

                        <h4 class="text-success mb-3">
                            Kết quả tra cứu
                        </h4>

                        <div class="table-responsive">

                            <table class="table table-bordered table-striped">

                                <thead class="table-primary">

                                    <tr>
                                        <th>Xã cũ</th>
                                        <th>Huyện cũ</th>
                                        <th>Tỉnh cũ</th>
                                        <th>Xã mới</th>
                                        <th>Tỉnh mới</th>
                                    </tr>

                                </thead>

                                <tbody>

                                    @foreach (var item in Model.DsXaMoi)
                                    {
                                        <tr>

                                            <td>
                                                @item.TenXaCu
                                            </td>

                                            <td>
                                                @item.TenHuyenCu
                                            </td>

                                            <td>
                                                @item.TenTinhCu
                                            </td>

                                            <td class="fw-bold text-success">
                                                @item.TenXaMoi
                                            </td>

                                            <td>
                                                @item.TenTinhMoi
                                            </td>

                                        </tr>
                                    }

                                </tbody>

                            </table>

                        </div>
                    }
                </div>

            </div>

        </div>

    </div>

</div>
@{
    ViewData["Title"] = "Tra cứu địa chỉ";
}

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-8">

            <div class="card shadow">

                <div class="card-header bg-primary text-white">

                    <h3 class="mb-0">
                        Tra cứu địa chỉ hành chính mới
                    </h3>

                </div>

                <div class="card-body">

                    <form asp-action="TimKiem"
                          method="post">

                        <div class="mb-3">

                            <label class="form-label">

                                Nhập địa chỉ cũ

                            </label>

                            <input type="text"
                                   name="diaChiCu"
                                   class="form-control"
                                   placeholder="Ví dụ: Xã Tân Phú..." />

                        </div>

                        <button type="submit"
                                class="btn btn-primary">

                            Tra cứu

                        </button>

                    </form>

                    @if (ViewBag.Message != null)
                    {
                        <div class="alert alert-danger mt-3">

                            @ViewBag.Message

                        </div>
                    }

                </div>

            </div>

        </div>

    </div>

</div>